{
  "name": "Travel-Log",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "db:up": "docker start libsql || docker run -d --name libsql -p 8080:8080 -v libsql-data:/var/lib/sqlite.db remodlai/libsql-server",
    "dev": "npm run db:up && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "npm run build && nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/icon": "^2.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tursodatabase/database": "^0.5.1",
    "better-auth": "^1.5.5",
    "daisyui": "^5.5.19",
    "dlx": "^0.2.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^1.0.0-beta.17-67b1795",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@iconify-json/material-symbols": "^1.2.62",
    "@nuxtjs/color-mode": "^4.0.0",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^1.0.0-beta.17-67b1795",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  }
}
